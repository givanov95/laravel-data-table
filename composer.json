{
    "name": "givanov95/laravel-data-table",
    "description": "A server-side DataTable builder for Laravel with a matching Vue 3 + Inertia frontend.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "data-table", "datatable", "inertia", "vue"],
    "authors": [
        {
            "name": "Georgi Ivanov",
            "email": "joroz95@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/pagination": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Givanov95\\DataTable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Givanov95\\DataTable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Givanov95\\DataTable\\DataTableServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php-cs-fixer fix --dry-run --diff"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
