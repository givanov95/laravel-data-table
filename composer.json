{
	"name": "givanov95/laravel-data-table",
	"description": "A server-side DataTable builder for Laravel with typed configuration.",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Georgi Ivanov",
			"email": "joroz95@gmail.com"
		}
	],
	"require": {
		"php": "^8.3",
		"illuminate/database": "^10.0|^11.0",
		"illuminate/http": "^10.0|^11.0",
		"illuminate/pagination": "^10.0|^11.0",
		"illuminate/support": "^10.0|^11.0"
	},
	"autoload": {
		"psr-4": {
			"Givanov95\\DataTable\\": "src/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^10.0",
		"friendsofphp/php-cs-fixer": "^3.0"
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
